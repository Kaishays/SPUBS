# =========================
# VS Code / Editor Files
# =========================
.vscode/
*.code-workspace

# =========================
# Python Cache & Bytecode
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual Environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Environment Variables & Secrets
# =========================
# Ignore all standard .env files
.env
.env.*
*.env

# Explicitly allow sample.env to be tracked
!sample.env

# =========================
# Logs and Databases
# =========================
*.log
*.sqlite3

# =========================
# OS Generated Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Testing & Coverage
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# Build & Distribution
# =========================
build/
dist/
*.egg-info/