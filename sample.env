# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# File and Model Paths
MODEL_PATH=/path/to/your/saved/model
PDF_PATH=./data/your_document.pdf
LOG_FILE_PATH=/path/to/your/logs/long_sentences_log.txt

# Database Tables & Identifiers
SENTENCE_TABLE=pdf_sentences
SENTENCE_COLUMNS=textId,sentenceIndex,pdfId,charIndex,charElement
EMBEDDING_TABLE=all-minilm-l6-v2_embeddings
EMBEDDING_COLUMNS=embeddingId,embeddingIndex,embeddingElementNormalized
TARGET_PDF_ID=your_target_pdf_id